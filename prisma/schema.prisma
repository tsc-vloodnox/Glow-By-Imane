generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  NOUVELLE
  DISCUSSION_WHATSAPP
  CONFIRMEE
  PREPARATION
  EN_LIVRAISON
  LIVREE
  ANNULEE
}

enum DeliveryStatus {
  PLANIFIEE
  EN_COURS
  LIVREE
  ECHOUEE
  REPORTEE
}

model Category {
  id       String    @id @default(cuid())
  name     String
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Int
  stock       Int         @default(0)
  favorite    Boolean     @default(false)
  archived    Boolean     @default(false)
  images      String[]
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
}

model Customer {
  id         String   @id @default(cuid())
  phone      String   @unique
  name       String
  quartier   String
  loyaltyPts Int      @default(0)
  vip        Boolean  @default(false)
  orders     Order[]
  createdAt  DateTime @default(now())
}

model Order {
  id             String      @id @default(cuid())
  number         Int         @unique @default(autoincrement())
  status         OrderStatus @default(NOUVELLE)
  source         String      @default("app")
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  name           String
  phone          String
  quartier       String
  comment        String?
  estimatedTotal Int
  discountAmount Int         @default(0)
  discountReason String?
  finalTotal     Int         @default(0)
  items          OrderItem[]
  delivery       Delivery?
  createdAt      DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Delivery {
  id          String         @id @default(cuid())
  orderId     String         @unique
  order       Order          @relation(fields: [orderId], references: [id])
  status      DeliveryStatus @default(PLANIFIEE)
  scheduledAt DateTime
  deliveredAt DateTime?
  livreur     String?
  deliveryFee Int            @default(0)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}
